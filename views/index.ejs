<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>v4 Demo</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script>
    window.node_crypto = new Proxy(crypto, {
      get(target, prop) {
        const val = target[prop];
        return typeof val === 'function' ? val.bind(target) : val;
      }
    });
  </script>
  <script src="https://cdn.jsdelivr.net/npm/@signalwire/js@4.0.0-beta.0/dist/browser.umd.js"></script>
</head>

<body class="flex items-center justify-center min-h-screen bg-gray-100">

  <div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-md space-y-6">
    <h1 class="text-2xl font-bold text-gray-800 text-center">SignalWire v4 Demo</h1>

    <div id="status" class="text-center text-sm text-gray-500">Connecting client…</div>

    <!-- Idle: dial panel -->
    <div id="dial-panel" class="space-y-3">
      <input id="destination" type="text" value="<%= defaultDestination %>" placeholder="/public/room"
        class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
      <button id="callBtn" disabled
        class="w-full bg-green-600 hover:bg-green-700 disabled:bg-gray-400 text-white font-semibold py-2 rounded-lg transition">Call</button>
    </div>

    <!-- Active: call panel (hidden by default) -->
    <div id="call-panel" class="space-y-4 hidden">
      <div class="text-center">
        <p id="call-dest" class="text-lg font-medium text-gray-700"></p>
        <p id="call-status" class="text-sm text-gray-500">Calling…</p>
        <p id="call-duration" class="text-3xl font-mono text-gray-800 mt-2">0:00</p>
      </div>

      <div class="flex gap-3">
        <button id="muteBtn"
          class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold py-2 rounded-lg transition">Mute</button>
        <button id="hangupBtn"
          class="flex-1 bg-red-600 hover:bg-red-700 text-white font-semibold py-2 rounded-lg transition">Hang
          Up</button>
      </div>

      <!-- Invite external number -->
      <div class="border-t pt-4 space-y-2">
        <p class="text-sm font-medium text-gray-600">Invite to conference</p>
        <input id="inviteNumber" type="text" value="+18004444444" placeholder="+1XXXXXXXXXX"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <div class="flex gap-3">
          <button id="inviteBtn"
            class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg transition">Invite</button>
          <button id="hangupInviteBtn" disabled
            class="flex-1 bg-gray-400 text-white font-semibold py-2 rounded-lg transition">Hang Up Invite</button>
        </div>
        <p id="invite-status" class="text-xs text-gray-400 text-center"></p>
      </div>
    </div>
  </div>
  <video id="localVideo" autoplay muted playsinline style="width: 1px; height: 1px"></video>
  <video id="remoteVideo" autoplay playsinline style="width: 1px; height: 1px"></video>

  <script>
    (async function () {


      // --- signalwire client auth helpers ---

      const TOKEN_EXPIRY_MS = 3600 * 1000;

      async function fetchSubscriberToken() {
        const response = await fetch('/token', {
          method: 'GET',
        });

        if (!response.ok) {
          const errorText = await response.text();
          throw new Error(`Subscriber auth failed: ${response.status} — ${errorText}`);
        }

        const data = await response.json();
        return data.token;
      }

      class SubscriberCredentialProvider {
        constructor() {}

        /**
         * Called once by the SDK during client initialization.
         * Fetches a fresh SAT and returns it to the SDK for initial authentication.
         *
         * @returns {Promise<import('@signalwire/js').SDKCredential>}
         */
        async authenticate() {
          const token = await fetchSubscriberToken();
          return { token, expiry_at: Date.now() + TOKEN_EXPIRY_MS };
        }

        /**
         * Called automatically by the SDK before the current token expires.
         * Re-fetches a fresh SAT using the same credentials.
         *
         * @returns {Promise<import('@signalwire/js').SDKCredential>}
         */
        async refresh() {
          return this.authenticate();
        }
      }

      const statusEl = document.getElementById('status');
      const callBtn = document.getElementById('callBtn');
      const hangupBtn = document.getElementById('hangupBtn');
      const muteBtn = document.getElementById('muteBtn');
      const destInput = document.getElementById('destination');
      const dialPanel = document.getElementById('dial-panel');
      const callPanel = document.getElementById('call-panel');
      const callDest = document.getElementById('call-dest');
      const callStatusEl = document.getElementById('call-status');
      const callDur = document.getElementById('call-duration');

      const inviteBtn = document.getElementById('inviteBtn');
      const hangupInvBtn = document.getElementById('hangupInviteBtn');
      const inviteInput = document.getElementById('inviteNumber');
      const inviteStatusEl = document.getElementById('invite-status');

      let currentCall = null;
      let durationInterval = null;
      let callStartTime = null;
      let invitedCallId = null;

      const STATUS_LABELS = {
        trying: 'Calling…',
        ringing: 'Ringing…',
        connecting: 'Connecting…',
        connected: 'Connected',
        disconnecting: 'Ending call…',
        disconnected: 'Call ended',
      };

      // --- UI helpers ---

      function showCallPanel(dest) {
        callDest.textContent = dest;
        callStatusEl.textContent = 'Calling…';
        callDur.textContent = '0:00';
        muteBtn.textContent = 'Mute';
        muteBtn.className = 'flex-1 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold py-2 rounded-lg transition';
        dialPanel.classList.add('hidden');
        callPanel.classList.remove('hidden');
        hangupBtn.disabled = false;
      }

      function resetInviteState() {
        invitedCallId = null;
        inviteBtn.disabled = false;
        hangupInvBtn.disabled = true;
        hangupInvBtn.className = 'flex-1 bg-gray-400 text-white font-semibold py-2 rounded-lg transition';
        inviteStatusEl.textContent = '';
      }

      function resetToIdle() {
        stopDurationTimer();
        resetInviteState();
        callPanel.classList.add('hidden');
        dialPanel.classList.remove('hidden');
        callBtn.disabled = false;
        hangupBtn.disabled = false;
        currentCall = null;
        statusEl.textContent = 'Ready — enter a destination and press Call';
        statusEl.className = 'text-center text-sm text-green-600';
      }

      function startDurationTimer() {
        callStartTime = Date.now();
        durationInterval = setInterval(() => {
          const elapsed = Math.floor((Date.now() - callStartTime) / 1000);
          const mins = Math.floor(elapsed / 60);
          const secs = elapsed % 60;
          callDur.textContent = `${mins}:${secs.toString().padStart(2, '0')}`;
        }, 1000);
      }

      function stopDurationTimer() {
        if (durationInterval) {
          clearInterval(durationInterval);
          durationInterval = null;
        }
      }

      // --- Client init ---

      const credentials = new SubscriberCredentialProvider();
      const client = new SignalWire.SignalWire(credentials);

      client.ready$.subscribe((ready) => {
        if (ready) {
          statusEl.textContent = 'Ready — enter a destination and press Call';
          statusEl.className = 'text-center text-sm text-green-600';
          callBtn.disabled = false;
        }
      });

      client.errors$.subscribe((err) => {
        console.error('Client error:', err);
        statusEl.textContent = 'Client error — check console';
        statusEl.className = 'text-center text-sm text-red-600';
      });

      // --- Call ---

      callBtn.addEventListener('click', async () => {
        const dest = destInput.value.trim();
        if (!dest) return;

        callBtn.disabled = true;
        statusEl.textContent = 'Requesting microphone…';
        statusEl.className = 'text-center text-sm text-yellow-600';

        // Request mic permission in click handler (user gesture)
        try {
          const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
          stream.getTracks().forEach((t) => t.stop());
        } catch (permErr) {
          console.error('Microphone permission denied:', permErr);
          statusEl.textContent = 'Microphone access denied';
          statusEl.className = 'text-center text-sm text-red-600';
          callBtn.disabled = false;
          return;
        }

        statusEl.textContent = 'Dialling…';

        try {
          currentCall = await client.dial(dest, { audio: true, video: false });
          showCallPanel(dest);

          // Subscribe to call status — handles ALL transitions including remote hangup
          currentCall.status$.subscribe((s) => {
            callStatusEl.textContent = STATUS_LABELS[s] || s;

            if (s === 'connected') {
              startDurationTimer();
            }

            if (s === 'disconnected' || s === 'destroyed') {
              resetToIdle();
            }
          });

          currentCall.remoteStream$.subscribe((stream) => {
            if (stream) {
              document.getElementById("remoteVideo").srcObject = stream
            }
          });

          currentCall.localStream$.subscribe((stream) => {
            document.getElementById('localVideo').srcObject = stream;
          });

          // Subscribe to mute state reactively via self$ (self is undefined until member events arrive)
          let muteSub;
          currentCall.self$.subscribe((self) => {
            if (!self) return;
            if (muteSub) muteSub.unsubscribe();
            if (self.audioMuted$) {
              muteSub = self.audioMuted$.subscribe((muted) => {
                muteBtn.textContent = muted ? 'Unmute' : 'Mute';
                if (muted) {
                  muteBtn.className = 'flex-1 bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 rounded-lg transition';
                } else {
                  muteBtn.className = 'flex-1 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold py-2 rounded-lg transition';
                }
              });
            }
          });
        } catch (err) {
          console.error('Dial failed:', err);
          statusEl.textContent = 'Dial failed — check console';
          statusEl.className = 'text-center text-sm text-red-600';
          currentCall = null;
          resetToIdle();
        }
      });

      // --- Hang up ---

      hangupBtn.addEventListener('click', () => {
        if (currentCall) {
          hangupBtn.disabled = true; // prevent double-click
          currentCall.hangup();
        }
      });

      // --- Mute ---

      muteBtn.addEventListener('click', () => {
        if (currentCall && currentCall.self) {
          currentCall.self.toggleMute();
        }
      });

      // --- Invite external number ---

      inviteBtn.addEventListener('click', async () => {
        const to = inviteInput.value.trim();
        if (!to) return;

        inviteBtn.disabled = true;
        inviteStatusEl.textContent = 'Calling…';
        inviteStatusEl.className = 'text-xs text-yellow-600 text-center';

        try {
          const resp = await fetch('/invite', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ to }),
          });
          const data = await resp.json();

          if (!resp.ok) {
            throw new Error(data.error || 'Invite failed');
          }

          invitedCallId = data.callId;
          inviteStatusEl.textContent = `Invited — ID: ${invitedCallId}`;
          inviteStatusEl.className = 'text-xs text-green-600 text-center';
          hangupInvBtn.disabled = false;
          hangupInvBtn.className = 'flex-1 bg-red-600 hover:bg-red-700 text-white font-semibold py-2 rounded-lg transition';
        } catch (err) {
          console.error('Invite error:', err);
          inviteStatusEl.textContent = err.message;
          inviteStatusEl.className = 'text-xs text-red-600 text-center';
          inviteBtn.disabled = false;
        }
      });

      hangupInvBtn.addEventListener('click', async () => {
        if (!invitedCallId) return;

        hangupInvBtn.disabled = true;
        inviteStatusEl.textContent = 'Hanging up…';
        inviteStatusEl.className = 'text-xs text-yellow-600 text-center';

        try {
          const resp = await fetch('/hangup-invite', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ callId: invitedCallId }),
          });

          if (!resp.ok) {
            const data = await resp.json();
            throw new Error(data.error || 'Hangup failed');
          }

          inviteStatusEl.textContent = 'Invite ended';
          inviteStatusEl.className = 'text-xs text-gray-500 text-center';
          resetInviteState();
        } catch (err) {
          console.error('Hangup invite error:', err);
          inviteStatusEl.textContent = err.message;
          inviteStatusEl.className = 'text-xs text-red-600 text-center';
          hangupInvBtn.disabled = false;
        }
      });
    })();
  </script>
</body>

</html>