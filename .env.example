# Your SignalWire space name (e.g. example.signalwire.com)
SIGNALWIRE_SPACE=yourspace.signalwire.com

# Project ID and API token from your SignalWire dashboard
SIGNALWIRE_PROJECT_ID=your-project-id
SIGNALWIRE_API_TOKEN=your-api-token

# A phone number from your SignalWire space, used as caller ID for outbound calls
FROM_NUMBER=+1XXXXXXXXXX

# Default dial destination shown in the UI (optional)
# DEFAULT_DESTINATION=/public/go-to-conference

# Server port (optional, defaults to 3002)
# PORT=3002
